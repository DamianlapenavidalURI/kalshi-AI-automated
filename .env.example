# Kalshi (DEMO ONLY)
KALSHI_ENV=demo
KALSHI_API_KEY_ID=""
# Path to your Kalshi private key (PEM). Keep this file OUT of git.
KALSHI_PRIVATE_KEY_PATH=
KALSHI_SSL_VERIFY=true
# Optional explicit CA bundle path override (usually not needed):
# KALSHI_SSL_CA_CERT=/absolute/path/to/cacert.pem

# Kalshi (PRODUCTION ONLY)
# KALSHI_ENV=prod
# KALSHI_API_KEY_ID=""
# Path to your Kalshi private key (PEM). Keep this file OUT of git.
# KALSHI_PRIVATE_KEY_PATH=

# Local persistence
DB_PATH=./data/kalshi_weather.sqlite3

# Deterministic spread cap used by signal layer
RISK_MAX_YES_SPREAD=0.22

# Deterministic signal settings (used in AI Agent)
SIGNAL_LOOKBACK_HOURS=48
SIGNAL_MAX_SNAPSHOTS_PER_MARKET=40
SIGNAL_MIN_SNAPSHOTS=3
SIGNAL_STALE_SECONDS=1800
SIGNAL_MAX_MID_VOLATILITY=0.12
SIGNAL_MAX_SINGLE_TICK_JUMP=0.2
SIGNAL_N_WINDOW=10
MIN_SIGNAL_SCORE=38 # pipeline floor
MIN_SIGNAL_SCORE_EXECUTION=38
MIN_SIGNAL_SCORE_GUARD=38

# AI orchestration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# LangGraph/LangSmith tracing (optional)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_PROJECT=kalshi-weather-demo

# Unified weather runtime
UNIFIED_MODE=dry_run # dry_run, shadow, live
UNIFIED_RUN=once # once, loop
UNIFIED_POLL_SECONDS=120 # integer seconds, e.g. 30, 60, 120
UNIFIED_HORIZON_DAYS=2 # integer days >= 1
UNIFIED_LIMIT_CANDIDATES=24 # integer count >= 1
UNIFIED_MAX_ENTRY_ORDERS=4 # integer count >= 1
UNIFIED_MAX_CONTRACTS_PER_ORDER=8 # float/integer >= 1
UNIFIED_AUTONOMY_PROFILE=high # safe, balanced, high
UNIFIED_TOP_N_DEEP_SEARCH=6 # integer >= 0
UNIFIED_DEEP_SEARCH_TIMEOUT_S=8 # float seconds per source call
UNIFIED_MIN_LIQUIDITY_CONTRACTS=8 # minimum combined yes/no book size
UNIFIED_REPEAT_MARKET_COOLDOWN_MINUTES=60 # anti-repeat same-market cooldown
UNIFIED_FINAL_ORCHESTRATOR_TEMPERATURE=0.35 # float 0..1
UNIFIED_CANDIDATE_SCAN_MULTIPLIER=4 # integer >= 1
UNIFIED_SCOUT_OVERRIDE_PRIORITY=70 # float 0..100
UNIFIED_DATA_FETCH_WORKERS=8 # integer >= 1, parallel SDK fetch workers

# Optional weather series tag filter. Leave empty/off by default.
UNIFIED_WEATHER_SERIES_TAG=
UNIFIED_AGENT_OUTPUT_JSON=./data/agent_outputs_latest.json # path string
UNIFIED_PRINT_AGENT_OUTPUTS=false # true, false
