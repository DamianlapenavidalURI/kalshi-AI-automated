# Kalshi (DEMO ONLY)
KALSHI_ENV=demo
KALSHI_API_KEY_ID=
# Path to your Kalshi private key (PEM). Keep this file OUT of git.
KALSHI_PRIVATE_KEY_PATH= # private key PEM path 
KALSHI_SSL_VERIFY=true # TLS certificate verification
# Optional explicit CA bundle path override (usually not needed):
# KALSHI_SSL_CA_CERT=/absolute/path/to/cacert.pem

# Kalshi (PRODUCTION ONLY)
#KALSHI_ENV=prod
#KALSHI_API_KEY_ID=
# Path to your Kalshi private key (PEM). Keep this file OUT of git.
#KALSHI_PRIVATE_KEY_PATH= # private key PEM path 
#KALSHI_SSL_VERIFY=true # TLS certificate verification

# Local persistence
DB_PATH=./data/kalshi_weather.sqlite3 # SQLite database file path | low: ./data/dev.sqlite3 | medium: ./data/kalshi_weather.sqlite3 | high: /secure/volume/kalshi_weather.sqlite3

# AI orchestration
OPENAI_API_KEY =  # OpenAI API secret key | low: empty/disabled | medium: project key (dev) | high: project key (production budget)
OPENAI_MODEL=gpt-4o-mini # model used for agent reasoning | low: lightweight mini | medium: standard model | high: strongest available reasoning model
OPENAI_MODEL_SCOUT=gpt-4o-mini # scout triage model | low: gpt-4o-mini | medium: gpt-4.1-mini | high: gpt-4.1
OPENAI_MODEL_CONTEXT=gpt-4o-mini # context synthesis model | low: gpt-4o-mini | medium: gpt-4.1-mini | high: gpt-4.1
OPENAI_MODEL_EDGE=gpt-4.1 # edge estimation model | low: gpt-4o-mini | medium: gpt-4.1 | high: o4-mini
OPENAI_MODEL_CRITIQUE=gpt-4o-mini # critique/check model | low: gpt-4o-mini | medium: gpt-4.1-mini | high: gpt-4.1
OPENAI_MODEL_FINAL=o4-mini # final orchestrator model | low: gpt-4.1-mini | medium: o4-mini | high: o3
OPENWEATHER_API_KEY= # OpenWeather API key for weather context | low: empty/disabled | medium: free-tier key | high: paid-tier key
OPENWEATHER_TTL_SECONDS=300 # weather cache time-to-live in seconds | low: 60 | medium: 300 | high: 900
# LangGraph/LangSmith tracing
LANGSMITH_TRACING=false # enable LangSmith traces 
LANGSMITH_API_KEY= # LangSmith API key | low: empty/disabled | medium: dev project key | high: team production key
LANGSMITH_PROJECT="kalshi-ai-betting" # LangSmith project name for grouping traces | low: local-test | medium: kalshi-ai-betting | high: org-prod-observability

# Unified weather runtime
UNIFIED_MODE=live # execution mode | low: dry_run | high: live
UNIFIED_RUN=once # scheduler behavior | low: once | medium: loop | high: loop (external service supervision)
UNIFIED_POLL_SECONDS=900 # legacy full-cycle cadence alias (seconds) | low: 300 | medium: 900 | high: 1800
UNIFIED_FULL_CYCLE_SECONDS=900 # heavy cycle cadence (discovery + deep research + entry) | low: 300 | medium: 900 | high: 1800
UNIFIED_RISK_WATCHER_SECONDS=20 # lightweight risk watcher cadence for open positions | low: 10 | medium: 20 | high: 60
UNIFIED_HORIZON_DAYS=5 # max days to market close for candidate discovery | low: 1 | medium: 2 | high: 5
UNIFIED_LIMIT_CANDIDATES=24 # max candidates evaluated per cycle | low: 8 | medium: 12 | high: 24
UNIFIED_MAX_ENTRY_ORDERS=4 # max new entry intents per cycle | low: 1 | medium: 2 | high: 4
UNIFIED_MAX_CONTRACTS_PER_ORDER=10 # max contracts in one order intent | low: 1 | medium: 4 | high: 10
UNIFIED_AUTONOMY_PROFILE=high # orchestration aggressiveness profile | low: safe | medium: balanced | high: high
UNIFIED_TOP_N_DEEP_SEARCH=6 # number of top candidates for deeper research | low: 0 | medium: 3 | high: 6
UNIFIED_DEEP_SEARCH_TIMEOUT_S=15 # timeout per deep-search source call (seconds) | low: 4 | medium: 8 | high: 15
UNIFIED_MIN_LIQUIDITY_CONTRACTS=4 # minimum combined orderbook contracts to proceed | low: 4 | medium: 8 | high: 20
UNIFIED_REPEAT_MARKET_COOLDOWN_MINUTES=60 # cooldown before re-entering same market | low: 10 | medium: 60 | high: 180
UNIFIED_REPEAT_THESIS_COOLDOWN_MINUTES=90 # cooldown before repeating same thesis | low: 15 | medium: 90 | high: 240
UNIFIED_FINAL_ORCHESTRATOR_TEMPERATURE=0.1 # LLM creativity/randomness for final decision | low: 0.10 | medium: 0.35 | high: 0.70
UNIFIED_CANDIDATE_SCAN_MULTIPLIER=8 # prefilter scan breadth multiplier | low: 2 | medium: 4 | high: 8
UNIFIED_CANDIDATE_SELECTION_MODE=ranked # candidate slice policy: ranked, random, or random_all | low: ranked | medium: random | high: random_all
UNIFIED_CANDIDATE_SELECTION_POOL_MULTIPLIER=3 # random mode pool factor (sample from top limit*factor) | low: 2 | medium: 3 | high: 5
UNIFIED_SCOUT_OVERRIDE_PRIORITY=50 # override threshold when scout says reject (0-100) | low: 50 | medium: 70 | high: 90
UNIFIED_DATA_FETCH_WORKERS=8 # parallel data fetch worker count | low: 2 | medium: 4 | high: 8

# Optional weather series tag filter. Leave empty/off by default.
UNIFIED_WEATHER_SERIES_TAG= # optional series filter (blank means all) | low: blank | medium: KXHIGH | high: specific narrow tag (e.g. KXHIGHLAX)
UNIFIED_AGENT_OUTPUT_JSON=./data/agent_outputs_latest.json # output JSON path | low: ./data/out.json | medium: ./data/agent_outputs_latest.json | high: /persistent/logs/agent_outputs_latest.json
UNIFIED_PRINT_AGENT_OUTPUTS=false # print full agent outputs in logs | low: false | medium: true (dev only) | high: true (with log redaction pipeline)
